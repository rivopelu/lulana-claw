{
  "name": "lulana-claw",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/index.ts",
    "dev:client": "cd client && bunx vite",
    "build": "bun run build:client && bun run build:server",
    "build:client": "cd client && bunx vite build",
    "build:server": "bun build src/index.ts --target bun --outdir dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "bunx eslint src __test__",
    "lint:fix": "bunx eslint src __test__ --fix",
    "format": "bunx prettier --write src __test__",
    "format:check": "bunx prettier --check src __test__",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "hono": "^4.12.2",
    "hono-decorators": "^0.2.0",
    "i18next": "^25.10.3",
    "mongoose": "^9.3.1",
    "openai": "^6.32.0",
    "pg": "^8.18.0",
    "picocolors": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0"
  }
}