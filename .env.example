# ─── Server ────────────────────────────────────────────────────────────────
PORT=8090
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lulana_claw
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_NAME=lulana_claw
# Leave empty if MongoDB has no authentication
MONGO_USER=
MONGO_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────────────────────
# Use a long random string (min 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_secret_string
JWT_EXPIRES_IN_DAY=30

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:5173/apps/google/callback (dev)
#                   https://yourdomain.com/apps/google/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/apps/google/callback

# ─── Supabase Storage (for content asset uploads) ────────────────────────────
# Create a project at https://supabase.com
# Storage → New bucket → name: "content-assets", toggle Public ON
# Project Settings → API → copy URL and service_role key
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=content-assets

# ─── Threads ─────────────────────────────────────────────────────────────────
# Separate Threads access token. Needs threads_basic + threads_content_publish scope.
# Get from: https://developers.facebook.com/apps → Threads → Access Tokens
# THREADS_USER_ID: If not set, falls back to INSTAGRAM_BUSINESS_ACCOUNT_ID.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ─── Instagram Content Publishing ────────────────────────────────────────────
# Create a Facebook App, connect Instagram Business Account, generate a long-lived token
# Docs: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Hour (0–23, local server time) at which Luna auto-generates a daily content draft
CONTENT_GENERATE_HOUR=9
